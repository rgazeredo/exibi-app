APP_NAME=Exibi
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Domain Configuration (for subdomain routing)
# Production: exibi.com.br (landing on root, app on app.exibi.com.br)
# Local: exibi.local or localhost
APP_DOMAIN=localhost

# Fortify auth routes domain (set to app.{domain} for subdomain routing)
# Leave empty for local development without subdomain
FORTIFY_DOMAIN=

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=exibi
DB_USERNAME=exibi
DB_PASSWORD=secret

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
# For subdomain routing, use .domain.com (with leading dot) to share session
# Production: .exibi.com.br | Local with subdomain: .exibi.local | Local without: null
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

# Cache (Redis)
CACHE_STORE=redis

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@exibi.local"
MAIL_FROM_NAME="${APP_NAME}"

# S3 Storage (MinIO for local development)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=exibi-media
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# For accessing MinIO from browser (public URLs)
AWS_URL=http://localhost:9000/exibi-media

# Super Admin (for seeder)
SUPER_ADMIN_EMAIL=admin@exibi.com.br
SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_PASSWORD=changeme123

# Sentry Error Tracking
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

VITE_APP_NAME="${APP_NAME}"
