# =============================================================================
# Exibi - Production Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your production environment.

APP_NAME=Exibi
APP_ENV=production
APP_KEY=  # Generate with: php artisan key:generate
APP_DEBUG=false
APP_URL=https://app.exibi.com.br

# Domain Configuration (for subdomain routing)
# - exibi.com.br -> Landing page
# - app.exibi.com.br -> Admin panel
APP_DOMAIN=exibi.com.br

# Fortify auth routes on app subdomain
FORTIFY_DOMAIN=app.exibi.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=exibi
DB_USERNAME=exibi
DB_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD

# Session - IMPORTANT: Use .domain for subdomain session sharing
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.exibi.com.br
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

# WebSocket (Soketi - Pusher-compatible)
PUSHER_APP_ID=exibi
PUSHER_APP_KEY=exibi-key
PUSHER_APP_SECRET=YOUR_SECURE_SOKETI_SECRET
PUSHER_HOST=soketi
PUSHER_PORT=6001
PUSHER_SCHEME=http
# Public host/port/scheme for browser WebSocket connections (via nginx proxy)
PUSHER_PUBLIC_HOST=ws.exibi.com.br
PUSHER_PUBLIC_PORT=443
PUSHER_PUBLIC_SCHEME=https

# Cache (Redis)
CACHE_STORE=redis

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (configure your SMTP provider)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailersend.net
MAIL_PORT=587
MAIL_USERNAME=YOUR_MAIL_USERNAME
MAIL_PASSWORD=YOUR_MAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@exibi.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# S3 Storage (Backblaze B2 or AWS S3)
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
AWS_DEFAULT_REGION=us-east-005
AWS_BUCKET=exibi-media
AWS_ENDPOINT=https://s3.us-east-005.backblazeb2.com
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=https://f005.backblazeb2.com/file/exibi-media

# Super Admin (initial setup only)
SUPER_ADMIN_EMAIL=admin@exibi.com.br
SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_PASSWORD=CHANGE_THIS_PASSWORD

# Widgets API (if using)
WIDGETS_API_URL=http://widgets-api:3000
WIDGETS_WEBHOOK_URL=https://app.exibi.com.br/api/webhooks/widget

VITE_APP_NAME="${APP_NAME}"
